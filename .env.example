# ── FastAPI ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080

# ── vLLM (OpenAI-compatible) ──────────────────────────────
# Внутри docker-сети сервис зовётся "vllm". С хоста — см. VLLM_HOST_PORT в README.
LLM_BASE_URL=http://vllm:8000/v1
LLM_API_KEY=dummy
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Qdrant ────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=scam_cases
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIM=768

# ── Neo4j ─────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=finguard_pass

# ── Postgres (сеансы анализа, ревью аналитика) ────────────
# В docker-сети хост = postgres; с локального хоста — localhost.
DATABASE_URL=postgresql+asyncpg://finguard:finguard_pass@postgres:5432/finguard
ENABLE_DB=true
POSTGRES_USER=finguard
POSTGRES_PASSWORD=finguard_pass
POSTGRES_DB=finguard

# ── Пайплайн / фичефлаги ──────────────────────────────────
# Позволяют отключать тяжёлые слои, если не успели поднять (план: «Риски и запасные варианты»).
ENABLE_SIMILARITY=true
ENABLE_GRAPH=true
ENABLE_LLM=true

# ── Deepfake-детектор (внешний репо в своём venv, изоляция зависимостей) ──
# Включается для /analyze/video → media_anomalies (possible_deepfake, synthetic_voice_suspected).
ENABLE_DEEPFAKE=false
DEEPFAKE_DIR=external/fakeface-detector
DEEPFAKE_PYTHON=external/fakeface-detector/.venv/bin/python
DEEPFAKE_TIMEOUT=120

# ── OSINT / репутация доменов ─────────────────────────────
# Эвристика (тайпсквоттинг KZ-брендов, подозрительные TLD) — офлайн, всегда.
# PhishTank — опционально (сеть): ENABLE_PHISHTANK=true (+ необязательный ключ).
ENABLE_OSINT=true
ENABLE_PHISHTANK=false
PHISHTANK_API_KEY=

# ── Данные ────────────────────────────────────────────────
DATA_DIR=/app/data
DATASET_PATH=/app/data/processed/ai_media_watch_dataset.jsonl
