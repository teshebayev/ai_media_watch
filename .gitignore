# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/

# env / secrets
.env

# data — сырьё и большие артефакты не коммитим (кроме .gitkeep и примеров)
data/raw/**
data/processed/*.jsonl
data/processed/*.csv
data/processed/*.log
data/shadow/*
!data/**/.gitkeep
# курируемый hold-out — версионируем (не регенерируется); негация работает только
# при глоб-форме data/shadow/* выше (директорная форма не даёт вернуть вложенный файл)
!data/shadow/holdout_real.jsonl

